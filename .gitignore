# Environment files — never commit secrets or local config.
.env
.env.*
!.env.example

# SQLite database + its write-ahead-log sidecar files (created at runtime).
*.db
*.db-shm
*.db-wal

# Rust build output (large, regenerated by `cargo build`).
backend/target/

# Node — the frontend has its own generated .gitignore, but keep these here as
# safety nets in case anything Node-related lands at the repo root.
node_modules/
.next/

# Python — worker/ container bytecode cache (created if handler.py is run/imported locally).
__pycache__/
*.pyc
*.pyo

# macOS Finder metadata (can appear in any directory).
.DS_Store

# Sample photo sets (photos-inbox/) ARE tracked — they're the preloaded sets the
# gallery serves, and the repo is public for judging, so only web-sized copies
# belong in git. Full-resolution originals stay local: a single 5712x4284 frame
# is ~5 MB, and the reconstruction pipeline rescales anything over --max-width
# (3840) on every load anyway.
photos-inbox/originals/

# Camera captures dropped at the repo root for a test run. These are tens of MB
# and there is no reason for one to enter history — a 16 MB scene.html already
# got swept in by a `git add -A` (d6e5e04) and is stuck there permanently.
/*.mov
/*.MOV
/*.mp4
/*.MP4