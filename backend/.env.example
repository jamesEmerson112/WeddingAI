# copy to .env; mock mode needs nothing filled in
MOCK_MODE=true                          # true = local demo (no GPU/credentials); false = real RunPod mode
PORT=8080                               # port the backend listens on
DATABASE_URL=sqlite://data.db?mode=rwc  # SQLite file; rwc = read-write, create the file if missing
RUNPOD_API_KEY=                         # RunPod API key (real mode only)
RUNPOD_ENDPOINT_ID=                     # RunPod serverless endpoint id (real mode only)
R2_ENDPOINT=                            # Cloudflare R2 S3-compatible endpoint URL (real mode, Phase 1)
R2_ACCESS_KEY_ID=                       # R2 access key id (real mode, Phase 1)
R2_SECRET_ACCESS_KEY=                   # R2 secret access key (real mode, Phase 1)
R2_BUCKET=                              # R2 bucket name that uploads land in (real mode, Phase 1)
R2_PUBLIC_BASE=                         # public base URL for serving scene artifacts (real mode, Phase 1)
