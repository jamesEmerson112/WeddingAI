# copy to .env.local
GEMINI_API_KEY=          # server-side only (app/api/analyze) — must NOT be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=     # backend base URL, e.g. https://weddingai-production.up.railway.app; empty = http://localhost:8080
NEXT_PUBLIC_DEMO_SCENE_URL=   # optional local-demo override: a real LichtFeld export dropped in
                               # public/demo/ (gitignored, e.g. /demo/scene-3041.html). When set,
                               # lib/api.ts's sceneUrl() swaps it in for the mock poller's
                               # placeholder scene.html so the viewer shows a real reconstruction.
                               # Leave empty on a fresh clone — there is no scene file to point at,
                               # and the viewer correctly falls back to the tracked placeholder.
