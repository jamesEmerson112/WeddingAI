# copy to .env.local
GEMINI_API_KEY=          # server-side only (app/api/analyze) — must NOT be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=     # backend base URL, e.g. https://weddingai-production.up.railway.app; empty = http://localhost:8080
NEXT_PUBLIC_DEMO_SCENE_URL=   # optional override of the scene lib/api.ts substitutes for the mock
                               # poller's placeholder scene.html. Defaults to the COMMITTED example
                               # export (/demo/scene-3041.html) when left empty, so a fresh clone
                               # needs nothing set here to see a real reconstruction. Only set this
                               # to point at a different scene instead (e.g. one hosted in a bucket
                               # later), or, deliberately, back to /demo/scene.html to disable the
                               # swap and show the honest placeholder again.
