# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated from photos-inbox/ by scripts/build-samples.mjs on predev/prebuild.
/public/samples/

# Real LichtFeld scene exports dropped here for local viewing. These are tens of
# MB — the tracked /public/demo/scene.html placeholder is the only scene that
# belongs in git. A 16 MB export already got swept into history (d6e5e04) and is
# stuck there permanently; serve real scenes from object storage instead.
/public/demo/scene-*.html
